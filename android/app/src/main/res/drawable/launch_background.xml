<?xml version="1.0" encoding="utf-8"?>
<!-- MM Market Splash Screen — Deep Blue background with properly sized centered logo -->
<!-- Uses dedicated splash_logo drawable (not ic_launcher_foreground) to prevent stretching -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- App theme primary color background: #1565C0 deep blue -->
    <item>
        <color android:color="#1565C0"/>
    </item>
    <!-- Centered MM Market logo — dedicated splash_logo asset, not ic_launcher_foreground -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
